{
  "expo": {
    "name": "Media",
    "slug": "media",
    "scheme": "media",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": { "backgroundColor": "#05070b" },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.media.app",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Media uses your library to attach photos and videos to posts."
      }
    },
    "android": {
      "package": "com.media.app",
      "permissions": ["READ_MEDIA_IMAGES", "READ_MEDIA_VIDEO", "POST_NOTIFICATIONS"]
    },
    "plugins": ["expo-image-picker", "expo-notifications"]
  }
}
